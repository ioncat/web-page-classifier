# docs-ru branch: DOCUMENTATION ONLY
# This branch contains ONLY Russian documentation, no code files

# Ignore everything by default
/*
!/.*

# Explicitly whitelist only documentation files and essential config
!.gitignore
!CLAUDE.md
!README.md
!docs/
!web/
!web/README.md
!web/docs/

# Ensure all markdown files in docs and web/docs are tracked
!docs/**
!web/docs/**
!web/README.md

# Explicitly ignore code files and other artifacts that shouldn't be here
web/venv/
web/app.py
web/routers/
web/static/
web/templates/
web/.env
*.py
__pycache__/
.venv/
venv/
